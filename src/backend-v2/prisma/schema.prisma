generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        Int             @id @default(autoincrement())
  username                  String          @unique
  email                     String          @unique
  password                  String
  fName                     String?
  lName                     String?
  userImage                 String?
  confirmationCode          String?
  confirmationCodeExpiresAt DateTime?
  lastConfirmationResend    DateTime?
  isActive                  Boolean         @default(false)
  refreshToken              String? 
  refreshTokenExpiresAt     DateTime?
  createdAt                 DateTime        @default(now())
  accountStatus             String          @default("active")
  friends                   Json?
  averageRating             Float           @default(0)
  isAdmin                   Boolean         @default(false)
  userImagePublicId         String?
  givenComments             Comment[]       @relation("GivenComments")
  receivedComments          Comment[]       @relation("ReceivedComments")
  conversationsAsUser1      Conversation[]  @relation("ConversationUser1")
  conversationsAsUser2      Conversation[]  @relation("ConversationUser2")
  sentMessages              Message[]       @relation("SenderMessages")
  receivedNotifications     Notification[]  @relation("UserReceivedNotifications")
  sentNotifications         Notification[]  @relation("UserSentNotifications")
  receivedRatings           Rating[]        @relation("ReceivedRatings")
  givenRatings              Rating[]        @relation("GivenRatings")
  reportsReceived           Report[]        @relation("ReportedUser")
  reportsSent               Report[]        @relation("Reporter")
  requests                  Request[]       @relation("UserRequests")
  routes                    Route[]         @relation("UserRoutes")
  seekerRequests            SeekerRequest[]
  devices                   UserDevice[]
}

model Rating {
  id        Int      @id @default(autoincrement())
  routeId   Int
  raterId   Int
  ratedId   Int
  score     Int
  comment   String?
  createdAt DateTime @default(now())
  rated     User     @relation("ReceivedRatings", fields: [ratedId], references: [id])
  rater     User     @relation("GivenRatings", fields: [raterId], references: [id])
  route     Route    @relation(fields: [routeId], references: [id])

  @@unique([routeId, raterId, ratedId])
}

model Comment {
  id          Int      @id @default(autoincrement())
  text        String
  rating      Int
  authorId    Int
  recipientId Int
  createdAt   DateTime @default(now())
  routeId     Int?
  author      User     @relation("GivenComments", fields: [authorId], references: [id])
  recipient   User     @relation("ReceivedComments", fields: [recipientId], references: [id])
  route       Route?   @relation(fields: [routeId], references: [id])

  @@index([recipientId])
}

model Route {
  id                 Int             @id @default(autoincrement())
  ownerId            Int
  selectedVehicle    String
  registrationNumber String?
  departureCityId    Int?
  departureCity      String
  departureStreet    String?
  departureNumber    String?
  arrivalCityId      Int?
  arrivalCity        String
  arrivalStreet      String?
  arrivalNumber      String?
  selectedDateTime   DateTime
  routeTitle         String?
  status             String          @default("active")
  createdAt          DateTime        @default(now())
  isSeekerRoute      Boolean         @default(false)
  comments           Comment[]
  ratings            Rating[]
  requests           Request[]       @relation("RouteRequests")
  departureCityRef   City?           @relation("RouteDepartureCity", fields: [departureCityId], references: [id])
  arrivalCityRef     City?           @relation("RouteArrivalCity", fields: [arrivalCityId], references: [id])
  owner              User            @relation("UserRoutes", fields: [ownerId], references: [id])
  seekerRequests     SeekerRequest[]
}

model SeekerRequest {
  id               Int       @id @default(autoincrement())
  departureCityId  Int?
  departureCity    String
  arrivalCityId    Int?
  arrivalCity      String
  routeTitle       String
  userId           Int
  createdAt        DateTime  @default(now())
  selectedDateTime DateTime
  status           String    @default("active")
  userEmail        String
  userFname        String
  userImage        String?
  userLname        String
  username         String
  routeId          Int?
  requests         Request[]
  departureCityRef City?     @relation("SeekerDepartureCity", fields: [departureCityId], references: [id])
  arrivalCityRef   City?     @relation("SeekerArrivalCity", fields: [arrivalCityId], references: [id])
  route            Route?    @relation(fields: [routeId], references: [id])
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id         Int          @id @default(autoincrement())
  text       String
  image      String?
  status     ReportStatus @default(PENDING)
  reporterId Int
  reportedId Int
  createdAt  DateTime     @default(now())
  reported   User         @relation("ReportedUser", fields: [reportedId], references: [id])
  reporter   User         @relation("Reporter", fields: [reporterId], references: [id])
}

model BugReport {
  id            Int      @id @default(autoincrement())
  userId        Int
  title         String
  description   String
  steps         String?
  image         String?
  appVersion    String
  platform      String
  systemVersion String
  deviceModel   String
  status        String   @default("open")
  createdAt     DateTime @default(now())
}

model Request {
  id              Int            @id @default(autoincrement())
  routeId         Int?
  userID          Int
  username        String
  userFname       String
  userLname       String
  userEmail       String
  userRouteId     Int
  departureCityId Int?
  departureCity   String
  arrivalCityId   Int?
  arrivalCity     String
  dataTime        DateTime
  requestComment  String
  status          String         @default("pending")
  rateCreator     Boolean        @default(false)
  rateUser        Boolean        @default(false)
  createdAt       DateTime       @default(now())
  toUserId        Int
  decidedAt       DateTime?
  read            Boolean        @default(false)
  seekerRequestId Int?
  route           Route?         @relation("RouteRequests", fields: [routeId], references: [id])
  seekerRequest   SeekerRequest? @relation(fields: [seekerRequestId], references: [id])
  departureCityRef City?         @relation("RequestDepartureCity", fields: [departureCityId], references: [id])
  arrivalCityRef   City?         @relation("RequestArrivalCity", fields: [arrivalCityId], references: [id])
  user            User           @relation("UserRequests", fields: [userID], references: [id])
}

model Notification {
  id              Int      @id @default(autoincrement())
  routeId         Int?
  message         String
  createdAt       DateTime @default(now())
  read            Boolean  @default(false)
  status          String   @default("active")
  senderId        Int
  conversationId  String?
  personalMessage String?
  requester       Json?
  approver        Json?
  recipientId     Int
  recipient       User     @relation("UserReceivedNotifications", fields: [recipientId], references: [id])
  sender          User     @relation("UserSentNotifications", fields: [senderId], references: [id])

  @@unique([recipientId, routeId, message, status])
}

model Conversation {
  id            Int       @id @default(autoincrement())
  routeId       Int?
  user1Id       Int
  user2Id       Int
  createdAt     DateTime  @default(now())
  arrivalCity   String
  departureCity String
  hiddenByUser1 Boolean   @default(false)
  hiddenByUser2 Boolean   @default(false)
  user1         User      @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2         User      @relation("ConversationUser2", fields: [user2Id], references: [id])
  messages      Message[]

  @@unique([routeId, user1Id, user2Id])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  text           String
  createdAt      DateTime     @default(now())
    read           Boolean      @default(false)
    conversation   Conversation @relation(fields: [conversationId], references: [id])
    sender         User         @relation("SenderMessages", fields: [senderId], references: [id])
    readAt         DateTime?
    deliveredAt    DateTime?
    @@index([conversationId])
    @@index([senderId])
  }

model UserDevice {
  id        Int      @id @default(autoincrement())
  userId    Int
  fcmToken  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model City {
  id             Int     @id @default(autoincrement())
  name           String  @unique
  normalizedName String
  countryCode    String  @default("BG")
  region         String?
  isActive       Boolean @default(true)
  popularity     Int     @default(0)
  createdAt      DateTime @default(now())
  departingRoutes Route[] @relation("RouteDepartureCity")
  arrivingRoutes  Route[] @relation("RouteArrivalCity")
  departureRequests Request[] @relation("RequestDepartureCity")
  arrivalRequests   Request[] @relation("RequestArrivalCity")
  departureSeekers  SeekerRequest[] @relation("SeekerDepartureCity")
  arrivalSeekers    SeekerRequest[] @relation("SeekerArrivalCity")

  @@index([name])
  @@index([normalizedName])
  @@index([isActive, popularity])
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}
